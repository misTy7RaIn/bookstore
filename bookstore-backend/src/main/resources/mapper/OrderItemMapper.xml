<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bookstore.mapper.OrderItemMapper">

    <!-- 按订单号查询明细 -->
    <select id="selectByOrderId" resultType="com.bookstore.pojo.OrderItem">
        SELECT * FROM order_item WHERE order_id = #{orderId}
    </select>

    <!-- 插入订单明细 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="orderItemId">
        INSERT INTO order_item (order_id, book_id, book_name, price, quantity)
        VALUES (#{orderId}, #{bookId}, #{bookName}, #{price}, #{quantity})
    </insert>

    <delete id="deleteByBookId">
        DELETE FROM order_item WHERE book_id = #{bookId}
    </delete>

</mapper>
