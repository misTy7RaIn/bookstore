<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bookstore.mapper.FavoriteMapper">

    <select id="selectByUserId" resultType="com.bookstore.pojo.Favorite">
        SELECT * FROM favorite WHERE user_id = #{userId}
    </select>

    <select id="selectByUserAndBook" resultType="com.bookstore.pojo.Favorite">
        SELECT * FROM favorite WHERE user_id = #{userId} AND book_id = #{bookId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="favoriteId">
        INSERT INTO favorite (user_id, book_id) VALUES (#{userId}, #{bookId})
    </insert>

    <delete id="deleteById">
        DELETE FROM favorite WHERE favorite_id = #{favoriteId}
    </delete>

    <delete id="deleteByBookId">
        DELETE FROM favorite WHERE book_id = #{bookId}
    </delete>

</mapper>
